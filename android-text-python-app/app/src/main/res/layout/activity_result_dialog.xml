<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/dialogCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/result_title"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/copyButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:minWidth="0dp"
                android:text="@string/result_copy_json"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/closeButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:text="@string/result_close"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/result_status_running"
            android:textColor="#0E7A0D"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/durationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/result_duration_running"
            android:textColor="#555555"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/messageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/result_message_running"
            android:textColor="#111111"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/stdoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#F4F4F4"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="@string/result_stdout_title_collapsed"
            android:textColor="#111111"
            android:visibility="gone" />

        <ScrollView
            android:id="@+id/stdoutContainer"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="#FAFAFA"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/stdoutText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#222222"
                android:textSize="12sp" />
        </ScrollView>

        <TextView
            android:id="@+id/stderrHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F4F4F4"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="@string/result_stderr_title_collapsed"
            android:textColor="#111111"
            android:visibility="gone" />

        <ScrollView
            android:id="@+id/stderrContainer"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="#FAFAFA"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/stderrText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#222222"
                android:textSize="12sp" />
        </ScrollView>

        <TextView
            android:id="@+id/tracebackHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#F4F4F4"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="@string/result_traceback_title_collapsed"
            android:textColor="#111111"
            android:visibility="gone" />

        <ScrollView
            android:id="@+id/tracebackContainer"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#FAFAFA"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tracebackText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="#222222"
                android:textSize="12sp" />
        </ScrollView>
    </LinearLayout>

</FrameLayout>
